    "then": {
      "add_cflag": "domain_undefined_oversight",
      "maturity_adjustments": {
        "oversight": -10,
        "governance": -5,
        "documentation": -5
      },
      "recommendations": ["rules.R01-X03.recommendation1"]
    }
  },
  {
  "id": "R01-X04",
