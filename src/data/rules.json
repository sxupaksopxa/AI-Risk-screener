          "field": "Q10",
          "equals": "yes"
        }
      ]
    },
    "then": {
      "add_regulatory_path": "possible_high_risk",      
      "risk_points": 15,
      "maturity_adjustments": {
        "governance": -5,
        "documentation": -5
      }
    }
  },
  {
    "id": "R01-X02",
    "category": "context",
    "name": "High-risk domain with consequential AI use",
