  {
    "id": "R01-X01",
    "category": "context",
    "name": "High-risk domain with material impact on people",
    "if": {
      "all": [
        {
          "field": "Q01",
          "in": ["healthcare", "employment_hr", "public_sector", "law_justice", "critical_infra"]
